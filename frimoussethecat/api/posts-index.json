---
layout: none
---
{% assign files = site.static_files | where_exp: "f", "f.path contains '/frimoussethecat/content/posts/'" %}
{
    "posts": [
        {%- for file in files %}
            {
                "title": "{{ file.basename }}",
                "filename": "{{ file.name }}",
                "filepath": "{{ file.path }}"
            }
        {%- endfor -%}
    ]
}